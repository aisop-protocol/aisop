[
  {
    "role": "system",
    "content": {
      "protocol": "AISOP V3.1",
      "id": "your.domain.project.task",
      "version": "1.0.0 stable",
      "name": "Standard AISOP Template",
      "description": "Standard template with description field.",
      "verified_on": [
        "Cursor",
        "Gemini CLI"
      ],
      "tools": [
        "shell"
      ],
      "parameters": {
        "target_dir": {
          "type": "string",
          "description": "Directory to process."
        }
      },
      "summary": "Short description of what this AISOP does.",
      "doc": "Detailed documentation. Explain the goal, inputs, and outputs here.",
      "system_prompt": "# Role: AISOP Virtual Runtime v3\nExecute blueprints.main"
    }
  },
  {
    "role": "user",
    "content": {
      "instruction": "Execute blueprints['main'].",
      "blueprints": {
        "main": "graph TD\n  start[Start Node] --> check{Decision?}\n  check -->|Yes| sub_task[Call Sub-Graph]\n  check -->|No| atomic_tool[Call Tool]\n  sub_task --> endNode((End))\n  atomic_tool --> endNode",
        "sub_task": "graph TD\n  sub_start --> sub_end"
      },
      "functions": {
        "simple_tool": {
          "step1": "echo 'Hello World'"
        },
        "multi_step_tool": {
          "step1": "echo 'Starting...'",
          "step2": "blueprints['sub_task']",
          "step3": "functions['simple_tool']",
          "step4": "echo 'Finished'"
        },
        "llm_tool": {
          "step1": {
            "op": "sys.llm",
            "prompt": "Analyze this..."
          }
        },
        "sub_task": {
          "step1": "blueprints['sub_task']"
        },
        "_comment": "Add your tool definitions above."
      }
    }
  }
]